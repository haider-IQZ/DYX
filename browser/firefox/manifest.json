{
  "manifest_version": 3,
  "name": "DYX Download Catcher",
  "version": "0.1.0",
  "description": "Automatically hand normal downloads from Firefox to DYX.",
  "permissions": [
    "cookies",
    "downloads",
    "nativeMessaging",
    "notifications",
    "storage",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DYX Download Catcher",
    "default_icon": {
      "16": "icons/dyx-16.png",
      "32": "icons/dyx-32.png",
      "48": "icons/dyx-48.png",
      "96": "icons/dyx-96.png"
    }
  },
  "icons": {
    "16": "icons/dyx-16.png",
    "32": "icons/dyx-32.png",
    "48": "icons/dyx-48.png",
    "96": "icons/dyx-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@dyx.app"
    }
  }
}
