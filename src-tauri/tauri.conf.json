{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DYX",
  "version": "0.1.0",
  "identifier": "app.dyx.downloadmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DYX",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
